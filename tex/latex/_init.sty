\newcommand*{\schemeLink}[2]{\href{#1#2}{\nolinkurl{#2}}}
\newcommand*{\mailtoLink}[1]{\schemeLink{mailto:}{#1}}
\newcommand*{\telLink}[1]{\schemeLink{tel:}{#1}}
\newcommand*{\httpLink}[1]{\schemeLink{http://}{#1}}
\newcommand*{\httpsLink}[1]{\schemeLink{https://}{#1}}
\newcommand*{\githubLink}[1]{\httpsLink{github.com/#1}}
\newcommand*{\pypiLink}[1]{\httpsLink{pypi.org/project/#1}}
\newcommand*{\npmLink}[1]{\httpsLink{npmjs.com/package/#1}}
\newcommand*{\mavenLink}[1]{\httpsLink{search.maven.org/artifact/#1}}
\newcommand*{\anonymousGithubLink}[1]{\httpsLink{anonymous.4open.science/r/#1}}
\newcommand*{\zenodoLink}[1]{\httpsLink{zenodo.org/records/#1}}
\newcommand*{\doiLink}[1]{\httpsLink{doi.org/#1}}
\newcommand*{\orcidLink}[1]{\httpsLink{orcid.org/#1}}

\newcommand*{\Emph}[1]{{\sffamily\bfseries #1}}
\newcommand*{\separator}{\nolinebreak\hspace{.5ex}\textperiodcentered{}\hspace{.5ex}}

\newcommand*{\maketoc}{
  \pagenumbering{roman}
  % \thispagestyle{empty}
  % \addtocontents{toc}{\protect\thispagestyle{empty}}
  \tableofcontents
  \cleardoublepage
  \pagenumbering{arabic}
  \setcounter{page}{1}
}
\newcommand*{\makefrontmatter}[1]{
  \frontmatter
  \maketitle
  \tableofcontents
  #1
  \cleardoublepage
  \mainmatter
}

\@ifundefined{abstract}{
  \newenvironment{abstract}
  {
    \cleardoublepage\thispagestyle{empty}\null\vfill
    \begin{center}
      \bfseries\abstractname
    \end{center}
    \noindent\ignorespaces
  }{
    \vfill\null
  }
}{}

