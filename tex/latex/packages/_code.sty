\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{_code}

\RequirePackage[chapter]{algorithm}

\RequirePackage[noend]{algpseudocode}
\algrenewcommand\alglinenumber[1]{\footnotesize #1}

\RequirePackage[newfloat=true]{minted}
\RequirePackage{caption}

% tex-fmt: off
\setminted{
  style=borland, % https://pygments.org/styles/
  linenos,
  breaklines,
  breakafter=),
  breakbefore=.,
  % breakbytoken,
  % breakbytokenanywhere,
  breakaftersymbolpre=,
  breakbeforesymbolpre=,
  breakanywheresymbolpre=,
  mathescape,
  autogobble,
  % framesep=2pt,
  fontsize=\scriptsize,
  tabsize=4,
  baselinestretch=1.0,
  xleftmargin=2em,
  frame=lines,
  vspace=0pt,
}
% tex-fmt: on

% default settings for inline code
\setmintedinline{}

% styling of line numbers in minted
\renewcommand{\theFancyVerbLine}{\ttfamily\scriptsize\arabic{FancyVerbLine}}

% support for page breaks in listings
\newenvironment{longlisting}{\captionsetup{type=listing}}{}

% allow references to line numbers
% https://tex.stackexchange.com/a/692526
\AddToHook{env/minted/begin}{\zcsetup{currentcounter=FancyVerbLine}}
\zcsetup{countertype={FancyVerbLine=line}}

